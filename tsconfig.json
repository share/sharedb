{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./lib",
    "target": "ES5",
    "module": "CommonJS",
    "types": [
      "node"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "noImplicitAny": false,
    "noImplicitThis": false,
  },
  "include": [
    "src/**/*.ts"
  ],
}